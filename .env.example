# ═══════════════════════════════════════════════════════════
# Project Sybil — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Neo4j ──────────────────────────────────────────────────
# Password for Neo4j database authentication
NEO4J_PASSWORD=sybilpass_changeme

# ── GitHub ─────────────────────────────────────────────────
# Create token: https://github.com/settings/tokens
# Required scopes: read:org, repo, read:user
GITHUB_TOKEN=ghp_xxxx
GITHUB_ORG=your-org-name

# ── Slack ──────────────────────────────────────────────────
# Create app: https://api.slack.com/apps → Bot Token
# Required scopes: channels:history, channels:read,
#   users:read, reactions:read
SLACK_BOT_TOKEN=xoxb-xxxx

# ── Jira ───────────────────────────────────────────────────
# Create token: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_HOST=yourcompany.atlassian.net
JIRA_EMAIL=admin@yourcompany.com
JIRA_TOKEN=xxxx

# ── Notion ─────────────────────────────────────────────────
# Create integration: https://www.notion.so/my-integrations
NOTION_TOKEN=secret_xxxx

# ── Application ───────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=generate_with_openssl_rand_hex_32
NODE_ENV=development
